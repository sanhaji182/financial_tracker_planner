{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Financial OS legacy source baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "captured_at",
    "git_sha",
    "deployed_commit",
    "compose_sha256",
    "containers",
    "manual_deploy_path"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "deployed_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "compose_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "containers": {
      "type": "array",
      "minItems": 5
    },
    "manual_deploy_path": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "const": "/usr/local/sbin/finance-deploy"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
