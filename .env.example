# App Configuration
APP_ENV=development
APP_PORT=8080
APP_SECRET=change-this-to-a-secure-secret-key-32-chars

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=financial_os
DB_USER=postgres
DB_PASSWORD=postgres_secret
DB_SSL_MODE=disable

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_ACCESS_SECRET=access-secret-key-change-this-in-production
JWT_REFRESH_SECRET=refresh-secret-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Worker Configuration
WORKER_URL=http://worker:8081
OCR_CONFIDENCE_THRESHOLD=0.7

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Telegram Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI & Automation (Optional)
AI_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY_VAULT_REF=
AI_MODEL=gpt-4o

# Vaultwarden Configuration
VAULT_URL=http://vaultwarden:80
VAULT_TOKEN=
